# GPU 서빙 인프라 설정 (setup_gpu.sh / onstart 용)
# 실제 값은 .env 에 넣고, 절대 커밋하지 말 것 (.gitignore 처리됨)

# Tailscale 인증 키 — Reusable + Ephemeral 권장
#   발급: https://login.tailscale.com/admin/settings/keys
#   - Reusable: 새 인스턴스마다 같은 키 재사용
#   - Ephemeral: 인스턴스 destroy 시 tailnet에서 노드 자동 제거(호스트명 충돌 방지)
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxx

# tailnet 안에서 GPU 서버가 가질 고정 호스트명 (Mac .env의 GPU_SERVER_URL이 이걸 가리킴)
TAILSCALE_HOSTNAME=vast-gpu-server-2
